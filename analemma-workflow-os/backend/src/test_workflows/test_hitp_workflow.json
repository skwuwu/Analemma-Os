{
    "workflow_name": "HITP Segmentation Test Workflow",
    "description": "Human-in-the-loop segmentation test workflow. All verifier-checked keys (hitp_prepared, TEST_RESULT, approval_result) are written PRE-HITP so they always reach final_state. HITP pause occurs after approval_required_node_2.",
    "nodes": [
        {
            "id": "prep_node",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "hitp_prepared"
            }
        },
        {
            "id": "prep_node_2",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "status": "hitp_prep_completed",
                    "ready_for_segmentation": true
                },
                "output_key": "prep_result"
            }
        },
        {
            "id": "validator_node",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "✅ SUCCESS: HITP preparation status confirmed",
                "output_key": "TEST_RESULT"
            }
        },
        {
            "id": "approval_required_node",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "requires_approval"
            }
        },
        {
            "id": "approval_required_node_2",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "status": "awaiting_human_approval",
                    "approval_type": "manual_review_required"
                },
                "output_key": "approval_result"
            }
        },
        {
            "id": "hitp_complete_marker",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "HITP flow completed",
                "output_key": "hitp_complete"
            },
            "label": "HITP 완료 마커 (post-HITP dummy)"
        }
    ],
    "edges": [
        {
            "source": "prep_node",
            "target": "prep_node_2"
        },
        {
            "source": "prep_node_2",
            "target": "validator_node"
        },
        {
            "source": "validator_node",
            "target": "approval_required_node"
        },
        {
            "source": "approval_required_node",
            "target": "approval_required_node_2"
        },
        {
            "source": "approval_required_node_2",
            "target": "hitp_complete_marker",
            "type": "hitp"
        }
    ],
    "start_node": "prep_node"
}
