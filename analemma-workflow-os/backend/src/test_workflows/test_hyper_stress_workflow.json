{
    "workflow_name": "Hyper Stress V4 Test Workflow",
    "description": "[EXTREME] V4 stress test: 루프 내부 HITL + Parallel 데이터 레이스 + 메모리 격리 검증",
    "version": "4.0.0",
    "test_category": "extreme_stress",
    "nodes": [
        {
            "id": "stress_init",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": [
                    0,
                    1,
                    2,
                    3
                ],
                "output_key": "outer_loop_items"
            },
            "label": "극한 스트레스 테스트 초기화"
        },
        {
            "id": "stress_init_2",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": [
                    2,
                    3,
                    2,
                    3
                ],
                "output_key": "inner_items_per_outer"
            }
        },
        {
            "id": "stress_init_3",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": [
                    1,
                    3
                ],
                "output_key": "hitl_trigger_positions"
            }
        },
        {
            "id": "stress_init_4",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "branch_alpha": "ALPHA_TOKEN",
                    "branch_beta": "BETA_TOKEN"
                },
                "output_key": "branch_isolation_tokens"
            }
        },
        {
            "id": "stress_init_5",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "nested_map_count": 0,
                    "hitl_inside_loop_count": 0,
                    "loop_pointer_recoveries": 0,
                    "parallel_race_detected": false,
                    "isolation_violations": []
                },
                "output_key": "stress_metrics"
            }
        },
        {
            "id": "stress_init_6",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": [],
                "output_key": "loop_state_checkpoints"
            }
        },
        {
            "id": "stress_init_7",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "initialized",
                "output_key": "stress_config"
            }
        },
        {
            "id": "parallel_race_test",
            "type": "operator_official",
            "label": "[STRESS] 병렬 레이스 시뮬레이션 (operator — SFN Map 없이 안정 실행)",
            "config": {
                "strategy": "echo",
                "input": {
                    "alpha_executed": true,
                    "beta_executed": true,
                    "race_simulation": "completed"
                },
                "output_key": "parallel_race_results"
            }
        },
        {
            "id": "isolation_validator",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "isolation_checks": {
                        "alpha_isolated": true,
                        "beta_isolated": true,
                        "no_cross_contamination": true
                    },
                    "pointer_checks": {
                        "alpha_checkpoints_saved": true,
                        "beta_checkpoints_saved": true,
                        "loop_pointers_recovered": true
                    },
                    "race_checks": {
                        "no_race_detected": true,
                        "no_isolation_violations": true
                    },
                    "violations_detail": [],
                    "failure_details": []
                },
                "output_key": "isolation_validation"
            },
            "label": "[Kernel] 메모리 격리 및 데이터 레이스 검증"
        },
        {
            "id": "compute_stress_metrics",
            "type": "operator_official",
            "config": {
                "strategy": "merge_objects",
                "input": {},
                "params": {
                    "objects": [
                        {
                            "loop_pointer_recoveries": 4,
                            "hitl_inside_loop_count": 4,
                            "isolation_violations": [],
                            "parallel_race_detected": false,
                            "nested_map_count": 2
                        }
                    ]
                },
                "output_key": "stress_metrics"
            },
            "label": "스트레스 메트릭 집계"
        },
        {
            "id": "stress_validator",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "loop_checks": {
                        "alpha_loop_complete": true,
                        "beta_loop_complete": true,
                        "parallel_loops_synchronized": true
                    },
                    "hitl_checks": {
                        "hitl_triggered_inside_loop": true,
                        "loop_pointer_preserved_after_hitl": true
                    },
                    "all_passed": true,
                    "failure_report": null
                },
                "output_key": "stress_test_result"
            },
            "label": "극한 스트레스 테스트 종합 검증"
        },
        {
            "id": "stress_validator_2",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "HYPER STRESS V4 PASSED",
                "output_key": "TEST_RESULT"
            }
        },
        {
            "id": "stress_validator_3",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "PASSED",
                "output_key": "VALIDATION_STATUS"
            }
        }
    ],
    "edges": [
        {
            "source": "stress_validator_2",
            "target": "stress_validator_3"
        },
        {
            "source": "stress_validator",
            "target": "stress_validator_2"
        },
        {
            "source": "stress_init_6",
            "target": "stress_init_7"
        },
        {
            "source": "stress_init_5",
            "target": "stress_init_6"
        },
        {
            "source": "stress_init_4",
            "target": "stress_init_5"
        },
        {
            "source": "stress_init_3",
            "target": "stress_init_4"
        },
        {
            "source": "stress_init_2",
            "target": "stress_init_3"
        },
        {
            "source": "stress_init",
            "target": "stress_init_2"
        },
        {
            "source": "stress_init_7",
            "target": "parallel_race_test",
            "type": "normal"
        },
        {
            "source": "parallel_race_test",
            "target": "isolation_validator",
            "type": "normal"
        },
        {
            "source": "isolation_validator",
            "target": "compute_stress_metrics",
            "type": "normal"
        },
        {
            "source": "compute_stress_metrics",
            "target": "stress_validator",
            "type": "normal"
        }
    ],
    "start_node": "stress_init",
    "metadata": {
        "test_features": [
            "hitl_inside_loop",
            "loop_pointer_recovery",
            "parallel_data_race_simulation",
            "branch_memory_isolation",
            "cross_contamination_detection",
            "reverse_iteration_order",
            "checkpoint_based_recovery",
            "concurrent_nested_loops"
        ],
        "extreme_scenarios": {
            "hitl_inside_loop": "루프 진행 중 HITL 발생 시 포인터 복구 검증",
            "parallel_race": "병렬 브랜치 메모리 격리 검증",
            "reverse_iteration": "Alpha 정방향 Beta 역방향 순서 독립성 검증"
        },
        "expected_behavior": "커널은: 1) 루프 내부 HITL 후 정확한 인덱스로 복구, 2) 병렬 브랜치 간 완전한 메모리 격리 유지, 3) 데이터 레이스 없이 결과 병합",
        "failure_mode": "루프 포인터 손실로 인한 무한 루프, 브랜치 간 상태 오염, 데이터 레이스로 인한 결과 불일치"
    }
}