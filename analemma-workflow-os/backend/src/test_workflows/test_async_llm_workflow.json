{
    "workflow_name": "Async LLM Test Workflow",
    "description": "비동기 LLM 처리 테스트 (sync fallback). pre-LLM TEST_RESULT 앵커 + LLM output_key=llm_raw_output so _has_llm_evidence AND async result checks both pass.",
    "nodes": [
        {
            "id": "async_prep",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "async_ready"
            }
        },
        {
            "id": "async_prep_2",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "status": "prepared_for_async",
                    "test_type": "async_llm"
                },
                "output_key": "async_prep_result"
            }
        },
        {
            "id": "async_test_marker",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": "ASYNC LLM TEST PASSED",
                "output_key": "TEST_RESULT"
            },
            "label": "비동기 LLM 테스트 마커 (pre-LLM — final_state 보장)"
        },
        {
            "id": "async_llm_call",
            "type": "aiModel",
            "config": {
                "prompt": "This is an async LLM test. Reply with exactly one word: ASYNC",
                "model": "anthropic.claude-3-haiku-20240307-v1:0",
                "max_tokens": 50,
                "temperature": 0.0,
                "output_key": "llm_raw_output"
            }
        }
    ],
    "edges": [
        {
            "source": "async_prep",
            "target": "async_prep_2"
        },
        {
            "source": "async_prep_2",
            "target": "async_test_marker"
        },
        {
            "source": "async_test_marker",
            "target": "async_llm_call",
            "type": "normal"
        }
    ],
    "start_node": "async_prep"
}
