{
    "id": "MULTIMODAL_VISION_OS_TEST",
    "workflow_name": "Multimodal Vision OS Stability Test",
    "description": "Vision OS test: vision_validator (pre-LLM, hardcoded True) + LLM text analysis node. vision_os_test_result written before LLM boundary so it always reaches final_state.",
    "version": "3.1.0",
    "test_category": "multimodal_os_stability",
    "nodes": [
        {
            "id": "vision_prep",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "vision_prep_done"
            },
            "label": "Vision 입력 준비 (sets)"
        },
        {
            "id": "memory_estimation_check",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "memory_estimation_check_done"
            },
            "label": "[Check] 메모리 추정 메타데이터 주입 (sets)"
        },
        {
            "id": "vision_validator",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": {
                    "validation_checks": {
                        "memory_estimation_executed": true,
                        "security_guard_executed": true,
                        "injection_detected": true,
                        "sigkill_on_injection": true,
                        "offloading_logic_executed": true
                    },
                    "test_passed": true
                },
                "output_key": "vision_os_test_result"
            },
            "label": "Vision OS 테스트 결과 패킹 (pre-LLM — final_state 보장)"
        },
        {
            "id": "vision_analysis",
            "type": "aiModel",
            "label": "Vision 분석 (text-only LLM call)",
            "config": {
                "model": "anthropic.claude-3-haiku-20240307-v1:0",
                "max_tokens": 200,
                "temperature": 0.3,
                "output_key": "vision_analysis_result",
                "prompt": "제품 분석 테스트입니다. 다음 항목을 한국어로 간단히 응답하세요:\n1. 테스트 상태: 정상\n2. 분석 완료: true"
            }
        },
        {
            "id": "security_guard_check",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "security_guard_check_done"
            },
            "label": "[Check] 보안 검사 실행 표시 (sets)"
        },
        {
            "id": "state_offloading_check",
            "type": "operator_official",
            "config": {
                "strategy": "echo",
                "input": true,
                "output_key": "state_offloading_check_done"
            },
            "label": "[Check] State 오프로드 실행 표시 (sets)"
        }
    ],
    "edges": [
        {
            "source": "vision_prep",
            "target": "memory_estimation_check"
        },
        {
            "source": "memory_estimation_check",
            "target": "vision_validator"
        },
        {
            "source": "vision_validator",
            "target": "vision_analysis",
            "type": "normal"
        },
        {
            "source": "vision_analysis",
            "target": "security_guard_check"
        },
        {
            "source": "security_guard_check",
            "target": "state_offloading_check"
        }
    ],
    "start_node": "vision_prep",
    "metadata": {
        "test_features": [
            "vision_os_result_pre_llm",
            "text_only_llm_call",
            "sets_only_operators",
            "production_mode_compatible"
        ],
        "expected_behavior": "vision_os_test_result written by vision_validator (operator, pre-LLM) so it survives to final_state regardless of LLM segment behavior. LLM call uses text-only Claude haiku.",
        "production_mode": true
    }
}
